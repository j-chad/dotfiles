{
	"$schema": "https://opencode.ai/config.json",
	"share": "disabled",
	"username": "Jackson",
	"autoupdate": "notify",
	"enabled_providers": [
		"github-copilot",
		"anthropic",
		"openai"
	],
	"small_model": "github-copilot/claude-haiku-4-5",
	"model": "github-copilot/claude-sonnet-4-6",
	"permission": {
		"*": "ask",
		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "ask",
			"go vet *": "allow"
		},
		"bash": {
			"*": "ask"
		},
		"task": {
			"*": "ask",
			"explore": "allow"
		},
		"glob": "allow",
		"grep": "allow",
		"list": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"question": "allow"
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": {}
    }
  }
}
